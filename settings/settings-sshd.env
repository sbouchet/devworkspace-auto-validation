#! /bin/bash

# Rough time (seconds) to wait for DevWorkspace to enter 'Running' state
export TIMEOUT=60

# name to give all created (singleton) DevWorkspace instances
export DEVWORKSPACE_NAME='sshd-test'

# url of the sample project to use for the DevWorkspace
export PROJECT_URL='"https://github.com/che-samples/web-nodejs-sample.git"'

# editor definition to be used for the DevWorkspace
export EDITOR_DEFINITION='https://raw.githubusercontent.com/eclipse-che/che-operator/refs/heads/main/editors-definitions/che-code-sshd-next.yaml'

# Function that evaluates whether DevWorkspace is valid
validate_devworkspace() {
  devfile_url=$1

  resolve_devworkspace_pod || return 1

  oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- cat /tmp/sshd.log &>/dev/null #always quiet this message an rely on return code
  if [ $? -eq 1 ]; then
    # fail to cat ssh log file
    debug "Failed to cat /tmp/sshd.log file on container"
    return 1
  fi
  res=$(oc exec -n ${DEVWORKSPACE_NS} ${podName} -c ${mainContainerName} -- cat /tmp/sshd.log | grep -q 'Server listening on')
  if [ $? -eq 0 ]; then
    # pass
    return 0
  else
    # fail
    debug "Failed to retrieve sucessfull sshd status log in /tmp/sshd.log file on container"
    return 1
  fi
}
